# SignalForge Basic Auth — example htpasswd file
#
# Format: <user>:<bcrypt-or-apr1-hash>
# DO NOT commit the real /etc/nginx/htpasswd-sf to git.
#
# ---------------------------------------------------------------------
# Create the real file on the server (first user — creates the file):
#
#     sudo htpasswd -B -c /etc/nginx/htpasswd-sf signalforge_admin
#
#   Flags:
#     -B  use bcrypt (recommended; safer than default md5/apr1)
#     -c  create new file (use ONLY for the first user — overwrites!)
#
# Add more users (do NOT pass -c):
#
#     sudo htpasswd -B /etc/nginx/htpasswd-sf analyst1
#     sudo htpasswd -B /etc/nginx/htpasswd-sf qa_team
#
# Delete a user:
#
#     sudo htpasswd -D /etc/nginx/htpasswd-sf old_user
#
# Verify a password:
#
#     htpasswd -v /etc/nginx/htpasswd-sf signalforge_admin
#
# Permissions (so only nginx + root can read it):
#
#     sudo chown root:www-data /etc/nginx/htpasswd-sf
#     sudo chmod 640           /etc/nginx/htpasswd-sf
# ---------------------------------------------------------------------

# Example entries (bcrypt hashes — replace before deploying):
signalforge_admin:$2y$05$REPLACE_ME_WITH_REAL_BCRYPT_HASH_FOR_ADMIN_USER_xxxxxxxxxxxx
analyst1:$2y$05$REPLACE_ME_WITH_REAL_BCRYPT_HASH_FOR_ANALYST_USER_xxxxxxxxxx
qa_team:$2y$05$REPLACE_ME_WITH_REAL_BCRYPT_HASH_FOR_QA_TEAM_USER_xxxxxxxxxxxx
