# =============================================================================
# SignalForge 환경변수 설정 (.env.example)
# 사용: cp .env.example .env  →  .env 수정 후 ./scripts/build.sh && ./scripts/up.sh
# =============================================================================

# ── 앱 식별자 (같은 서버에 여러 인스턴스 공존 시 변경) ───────────────────
# Apptainer instance 이름 prefix: sf_postgres, sf-backend 등에 사용됨
APP_NAME=sf

# ── 프록시 (사내망 등) ────────────────────────────────────────────────────
# 외부 환경(사내망 밖)에서 프록시 완전 비활성: BUILD_PROXY_HTTPS=off
# _common.sh 의 DEFAULT_FALLBACK_PROXY (168.219.61.252:8080) 가 자동 적용됨
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=
BUILD_PROXY_HTTPS=
BUILD_PROXY_HTTP=

# ── PostgreSQL (Apptainer instance) ─────────────────────────────────────────
POSTGRES_USER=signalforge
POSTGRES_PASSWORD=signalforge_pass
POSTGRES_DB=signalforge
POSTGRES_HOST=127.0.0.1
# 호스트가 이미 5432 점유 중이면 다른 포트로 변경
POSTGRES_PORT=5432

# ── Redis (시스템 서비스 — sudo grep requirepass /etc/redis/redis.conf) ────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=Soseks314!
# REDIS_URL 은 up.sh 가 위 변수로부터 자동 생성 (수동 override 가능)
REDIS_URL=

# ── Claude API (NLP + MCP) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── LLM 인사이트 (Track B) ──────────────────────────────────────────────────
# crawler/insight/daily_insight.py — 어제 VOC 데이터를 LLM 으로 요약
# 우선순위: ANTHROPIC_API_KEY (claude-sonnet-4-5) → OPENAI_API_KEY (gpt-4o-mini)
# 둘 다 비워두면 LLM 호출은 skip 되고 raw 요약만 reports/insight_YYYY-MM-DD.md 에 저장됨
OPENAI_API_KEY=
# 선택: LLM 타임아웃 / 출력 토큰 한계 / 재시도 횟수 (기본값 사용 OK)
LLM_TIMEOUT_SEC=60
LLM_MAX_TOKENS=4096
LLM_RETRY=1
# 선택: 보고서 출력 디렉토리 (기본: <repo>/reports)
REPORT_DIR=

# ── 번역 ────────────────────────────────────────────────────────────────────
DEEPL_API_KEY=
LIBRE_TRANSLATE_URL=

# ── Reddit API (PRAW) ───────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SignalForge/1.0

# ── Naver Cafe (선택) ───────────────────────────────────────────────────────
NAVER_ID=
NAVER_PASSWORD=

# ── Twitter / X ─────────────────────────────────────────────────────────────
TWITTER_USERNAME=
TWITTER_PASSWORD=

# ── Backend API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=18000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_KEY=change-me
DEBUG=false
LOG_LEVEL=INFO

# ── MCP 서버 ────────────────────────────────────────────────────────────────
MCP_PORT=8001

# ── Celery ──────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
