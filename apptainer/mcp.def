Bootstrap: docker
From: python:3.12-slim

%labels
    Maintainer SignalForge
    Version 1.0
    Service mcp-server

%help
    SignalForge MCP 서버 컨테이너.
    실행: apptainer instance start --bind $PROJECT_ROOT/mcp-server:/mcp-server \
             apptainer/mcp.sif mcp-server

%post
    apt-get update && apt-get install -y \
        gcc \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        mcp[cli]==1.3.0 \
        sqlalchemy[asyncio]==2.0.36 \
        asyncpg==0.30.0 \
        python-dotenv==1.0.1 \
        anthropic==0.40.0 \
        httpx==0.28.0

%environment
    export PYTHONPATH=/mcp-server
    export PYTHONUNBUFFERED=1

%runscript
    cd /mcp-server && exec python server.py "$@"

%startscript
    cd /mcp-server && exec python server.py
