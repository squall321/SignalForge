Bootstrap: docker
From: python:3.12-slim

%labels
    Maintainer SignalForge
    Version 1.0
    Service crawler

%help
    SignalForge Celery 크롤러 워커 컨테이너 (Playwright 포함).
    빌드 후 worker/beat 둘 다 이 이미지를 사용한다.
    worker: apptainer instance start --bind $PROJECT_ROOT/crawler:/crawler \
                apptainer/crawler.sif celery-worker
    beat:   apptainer instance start --bind $PROJECT_ROOT/crawler:/crawler \
                apptainer/crawler.sif celery-beat

%post
    apt-get update && apt-get install -y \
        gcc \
        libpq-dev \
        curl \
        wget \
        libnss3 \
        libnspr4 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libdbus-1-3 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2 \
        libpango-1.0-0 \
        libcairo2 \
    && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        celery[redis]==5.4.0 \
        playwright==1.48.0 \
        praw==7.8.1 \
        httpx==0.28.0 \
        beautifulsoup4==4.12.3 \
        lxml==5.3.0 \
        langdetect==1.0.9 \
        deep-translator==1.11.4 \
        vaderSentiment==3.3.2 \
        sqlalchemy[asyncio]==2.0.36 \
        asyncpg==0.30.0 \
        python-dotenv==1.0.1 \
        anthropic==0.40.0

    # Playwright Chromium 설치 (런타임 라이브러리는 위 apt-get 에서 이미 설치됨;
    # --with-deps 는 ttf-unifont / ttf-ubuntu-font-family 미존재(trixie)로 실패하므로 제거)
    playwright install chromium

%environment
    export PYTHONPATH=/crawler
    export PYTHONUNBUFFERED=1

%runscript
    # 기본: worker 실행 (인자로 오버라이드 가능)
    cd /crawler && exec celery -A celery_app worker --loglevel=info --concurrency=4 "$@"

%startscript
    cd /crawler && exec celery -A celery_app worker --loglevel=info --concurrency=4
