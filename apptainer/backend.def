Bootstrap: docker
From: python:3.12-slim

%labels
    Maintainer SignalForge
    Version 1.0
    Service backend

%help
    SignalForge FastAPI 백엔드 컨테이너.
    실행: apptainer instance start --bind $PROJECT_ROOT/backend:/app \
             apptainer/backend.sif backend
    중지: apptainer instance stop backend

%post
    apt-get update && apt-get install -y \
        gcc \
        libpq-dev \
        curl \
    && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        fastapi==0.115.0 \
        uvicorn[standard]==0.30.0 \
        sqlalchemy[asyncio]==2.0.36 \
        asyncpg==0.30.0 \
        alembic==1.14.0 \
        pydantic==2.9.2 \
        pydantic-settings==2.6.0 \
        python-dotenv==1.0.1 \
        redis==5.2.0 \
        httpx==0.28.0 \
        anthropic==0.40.0

%environment
    export PYTHONPATH=/app
    export PYTHONUNBUFFERED=1

%runscript
    exec uvicorn app.main:app --host 0.0.0.0 --port 8000 "$@"

%startscript
    exec uvicorn app.main:app --host 0.0.0.0 --port 8000
